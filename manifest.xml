<iq:manifest version="3" xmlns:iq="http://www.garmin.com/xml/connectiq">
    <!--
        Penumbra - a bright, data-dense digital watch face. Three large digit groups
        show HH MM SS (accent-coloured seconds), ringed by a full set of icon
        complications (heart rate, steps, distance, calories, floors, body battery,
        device battery, notifications, alarms, live weather condition + hi/lo). Light
        and dark themes plus a selectable accent colour.

        Everything is laid out relative to dc.getWidth()/getHeight() and the screen
        centre, and the big digits use the built-in numeric system fonts, so the same
        source scales across every round panel size with no per-resolution font assets.

        Targets CIQ 4.0+ round watches. minApiLevel 4.0.0 guarantees the Body Battery
        SensorHistory API (4.0+); every optional feature is still guarded with `has`
        checks at runtime so nothing crashes on a device that lacks it.
    -->
    <iq:application id="b7e4d2a1-9c63-4f08-ae15-3d6f2c8b40e9" type="watchface" name="@Strings.AppName" entry="PenumbraApp" launcherIcon="@Drawables.LauncherIcon" minApiLevel="4.0.0">
        <iq:products>
            <!-- Forerunner -->
            <iq:product id="fr165"/>
            <iq:product id="fr165m"/>
            <iq:product id="fr255"/>
            <iq:product id="fr255m"/>
            <iq:product id="fr255s"/>
            <iq:product id="fr255sm"/>
            <iq:product id="fr265"/>
            <iq:product id="fr265s"/>
            <iq:product id="fr57042mm"/>
            <iq:product id="fr57047mm"/>
            <iq:product id="fr955"/>
            <iq:product id="fr965"/>
            <iq:product id="fr970"/>

            <!-- fenix / epix / enduro -->
