<strings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">
    <string id="AppName">Penumbra</string>

    <!-- Theme -->
    <string id="ThemeTitle">Theme</string>
    <string id="ThemePrompt">Light shows black digits on a white background; Dark shows white digits on a black background.</string>
    <string id="ThemeLight">Light (white)</string>
    <string id="ThemeDark">Dark (black)</string>

    <!-- Accent colour of the flip cards -->
    <string id="AccentTitle">Card Accent Colour</string>
    <string id="AccentPrompt">Colour of the three time cards behind the digits.</string>
    <string id="AccentOrange">Orange</string>
    <string id="AccentBlue">Blue</string>
    <string id="AccentGreen">Green</string>
    <string id="AccentRed">Red</string>
    <string id="AccentYellow">Yellow</string>

    <!-- Seconds -->
    <string id="ShowSecondsTitle">Show Seconds</string>
    <string id="ShowSecondsPrompt">Show the seconds card. Turning this off can save battery on AMOLED watches.</string>

    <!-- Date -->
    <string id="ShowDateTitle">Show Date</string>
    <string id="ShowDatePrompt">Show the weekday and day-of-month above the time.</string>

    <!-- Weather -->
    <string id="ShowWeatherTitle">Show Weather</string>
    <string id="ShowWeatherPrompt">Show the current temperature and daily high/low when weather data is available.</string>

    <!-- Step-goal eclipse ring -->
    <string id="ShowGoalArcTitle">Show Goal Ring</string>
    <string id="ShowGoalArcPrompt">Show the eclipse ring around the edge that fills as you approach your daily step goal.</string>

    <!-- Configurable complication slots -->
    <string id="SlotPrompt">Choose which data this slot shows.</string>
    <string id="SlotMLTitle">Slot: Left of Time</string>
    <string id="SlotMRTitle">Slot: Right of Time</string>
    <string id="SlotLLTitle">Slot: Lower Left</string>
    <string id="SlotLCTitle">Slot: Lower Centre</string>
    <string id="SlotLRTitle">Slot: Lower Right</string>

    <!-- Data-type names shared by every slot picker -->
    <string id="DataHR">Heart Rate</string>
    <string id="DataBB">Body Battery</string>
    <string id="DataSteps">Steps</string>
    <string id="DataCalories">Calories</string>
    <string id="DataDistance">Distance</string>
    <string id="DataFloors">Floors</string>
    <string id="DataAlarms">Alarms</string>
    <string id="DataNotifs">Notifications</string>
    <string id="DataNone">None</string>
</strings>
