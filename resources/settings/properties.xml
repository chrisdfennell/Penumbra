<properties>
    <!-- 0 = Light (white background, black digits), 1 = Dark (black background, white digits) -->
    <property id="Theme" type="number">0</property>

    <!-- Flip-card accent colour. 0=Orange 1=Blue 2=Green 3=Red 4=Yellow -->
    <property id="Accent" type="number">0</property>

    <!-- Show the seconds card -->
    <property id="ShowSeconds" type="boolean">true</property>

    <!-- Show the date above the time -->
    <property id="ShowDate" type="boolean">true</property>

    <!-- Show the weather complication (temp + hi/lo) -->
    <property id="ShowWeather" type="boolean">true</property>

    <!-- Show the step-goal eclipse ring around the edge -->
    <property id="ShowGoalArc" type="boolean">true</property>

    <!-- Show a heart-rate trend sparkline in place of the lower complication row -->
    <property id="ShowHrGraph" type="boolean">false</property>

    <!-- Configurable complication slots. Data types:
         0=Heart Rate 1=Body Battery 2=Steps 3=Calories 4=Distance
         5=Floors 6=Alarms 7=Notifications 8=None -->
    <property id="SlotML" type="number">0</property>  <!-- margin left  -->
    <property id="SlotMR" type="number">1</property>  <!-- margin right -->
    <property id="SlotLL" type="number">4</property>  <!-- lower left   -->
    <property id="SlotLC" type="number">3</property>  <!-- lower centre -->
    <property id="SlotLR" type="number">5</property>  <!-- lower right  -->
</properties>
