# Local/temporary script files
compress.ps1
*temp*
# The broad *temp* rule above also matches GitHub's *TEMPLATE* paths on
# case-insensitive filesystems -- explicitly keep those tracked.
!.github/PULL_REQUEST_TEMPLATE.md
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/**

# Local build configurations
build_config.json
